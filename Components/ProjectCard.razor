<div class="group">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
        <div class="@(ImageOnRight ? "lg:col-span-7 lg:order-2" : "lg:col-span-7")">
            <div class="relative aspect-video rounded-2xl overflow-hidden bg-cream-deep shadow-warm transition-transform duration-500 group-hover:-translate-y-2">
                @if (!string.IsNullOrWhiteSpace(ScreenshotUrl))
                {
                    <img src="@ScreenshotUrl" alt="@Title screenshot" class="w-full h-full object-cover" />
                }
                else
                {
                    <div class="w-full h-full flex items-center justify-center">
                        <span class="font-display italic text-9xl text-ink/10" style="font-variation-settings: 'opsz' 144, 'SOFT' 100;">@Title.Substring(0, 1)</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(LiveUrl) || !string.IsNullOrWhiteSpace(GitHubUrl))
                {
                    <div class="absolute inset-0 bg-ink/30 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                        <span class="font-display italic text-cream text-2xl" style="font-variation-settings: 'opsz' 144, 'SOFT' 100;">view &rarr;</span>
                    </div>
                }
            </div>
        </div>

        <div class="@(ImageOnRight ? "lg:col-span-5 lg:order-1 lg:pt-12" : "lg:col-span-5 lg:pt-12")">
            <div class="flex items-baseline gap-3 mb-4">
                <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-mute">@Number</span>
                <span class="h-px flex-1 bg-ink/15"></span>
                @if (!string.IsNullOrWhiteSpace(Category))
                {
                    <span class="font-mono text-[10px] uppercase tracking-[0.3em] @CategoryClasses">@Category</span>
                }
            </div>

            <h3 class="font-display text-5xl md:text-6xl font-medium text-ink group-hover:text-accent transition-colors mb-6 tracking-[-0.02em]" style="font-variation-settings: 'opsz' 144, 'SOFT' 50;">@Title<span class="text-accent">.</span></h3>

            <p class="text-ink-soft text-base md:text-lg leading-relaxed mb-8">@Description</p>

            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1 mb-8 pb-6 border-b border-ink/10">
                @for (int i = 0; i < TechStack.Count; i++)
                {
                    <span class="font-mono text-[11px] uppercase tracking-[0.15em] text-ink-mute">@TechStack[i]</span>
                    @if (i < TechStack.Count - 1)
                    {
                        <span class="text-ink-mute/40">/</span>
                    }
                }
            </div>

            <div class="flex items-center gap-6">
                @if (!string.IsNullOrWhiteSpace(LiveUrl))
                {
                    <a href="@LiveUrl" target="_blank" rel="noopener noreferrer" class="group/link font-display italic text-ink hover:text-accent inline-flex items-center gap-2 transition-colors" style="font-variation-settings: 'opsz' 36, 'SOFT' 100;">
                        Live demo
                        <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <line x1="5" y1="12" x2="19" y2="12" />
                            <polyline points="12 5 19 12 12 19" />
                        </svg>
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(GitHubUrl))
                {
                    <a href="@GitHubUrl" target="_blank" rel="noopener noreferrer" class="group/link font-display italic text-ink-mute hover:text-ink inline-flex items-center gap-2 transition-colors" style="font-variation-settings: 'opsz' 36, 'SOFT' 100;">
                        GitHub
                        <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <line x1="5" y1="12" x2="19" y2="12" />
                            <polyline points="12 5 19 12 12 19" />
                        </svg>
                    </a>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public List<string> TechStack { get; set; } = new();
    [Parameter] public string GitHubUrl { get; set; } = "";
    [Parameter] public string LiveUrl { get; set; } = "";
    [Parameter] public string ScreenshotUrl { get; set; } = "";
    [Parameter] public string Category { get; set; } = "";
    [Parameter] public string CategoryColor { get; set; } = "teal";
    [Parameter] public bool ImageOnRight { get; set; } = false;
    [Parameter] public string Number { get; set; } = "";

    string CategoryClasses => CategoryColor switch
    {
        "teal" => "text-chip-tealfg",
        "purple" => "text-chip-purplefg",
        "coral" => "text-chip-coralfg",
        "blue" => "text-chip-bluefg",
        "green" => "text-chip-greenfg",
        _ => "text-accent",
    };
}
